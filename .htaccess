# SATK — Apache rewrite rules für Pretty URLs
# Funktioniert auf IONOS-Webspace (Apache mit mod_rewrite)

RewriteEngine On

# /index.html → / (301, kanonische Homepage-URL)
RewriteRule ^index\.html$ / [R=301,L]

# Alle anderen .html → ohne Extension (301)
# Trigger: nur originale HTTP-Requests (THE_REQUEST), nicht interne Rewrites
RewriteCond %{THE_REQUEST} ^[A-Z]+\ /([^.]+)\.html[\ ?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Saubere URL → intern auf .html-Datei (URL bleibt clean im Browser)
# Nur wenn die Datei nicht direkt existiert und auch kein Verzeichnis ist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# Optional: HTTPS erzwingen (falls IONOS nicht schon redirected)
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Cache für statische Assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Komprimierung
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Security-Headers (HTTP-Antwortheader fuer alle Responses)
# Setzt HSTS plus die Standard-Schutz-Header. Cloudflare's eigene HSTS-
# Konfiguration (SSL/TLS -> Edge Certificates) kann das ergaenzen, ist
# aber nicht zwingend — der Header hier wird durch Cloudflare durchgereicht.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self \"https://buy.paddle.com\")"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # Content-Security-Policy — ueber mehrere Zeilen aufgeteilt mit Backslash,
  # weil IONOS Apache lange Single-Line-Werte mit vielen Sonderzeichen
  # nicht zuverlaessig akzeptiert.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.paddle.com https://buy.paddle.com https://*.paddle.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://*.paddle.com https://*.paddle.io https://download.satk.tech; frame-src https://buy.paddle.com https://*.paddle.com; frame-ancestors 'none'; form-action 'self' https://buy.paddle.com; base-uri 'self'; object-src 'none'"
</IfModule>
